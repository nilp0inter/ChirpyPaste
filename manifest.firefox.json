{
  "manifest_version": 3,
  "name": "ChirpyPaste",
  "version": "1.0.0",
  "description": "Decode Chirpy audio transmissions and paste into text fields",
  "permissions": [],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Toggle ChirpyPaste recording"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "chirpypaste@nilp0inter.com",
      "strict_min_version": "109.0"
    }
  }
}
